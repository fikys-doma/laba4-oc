#pragma comment (lib, "winmm.lib")
#include "windows.h"
#include <iostream>
#include "fstream"
#include "time.h"
#include <iomanip>
#include <string>
#include <fcntl.h>
#include <io.h>

using namespace std;

// Глобальные дескрипторы объектов синхронизации
HANDLE mutex;           // Мьютекс для защиты счетчика активных читателей
HANDLE wrt;            // Семафор для управления доступом писателей (1 - свободен, 0 - занят)
HANDLE* pageMutexes;   // Массив мьютексов для блокировки отдельных страниц буфера
int readCount = 0;     // Количество читателей, активных в данный момент

// Количество страниц буферной памяти
// Вычисляется как сумма цифр номера студенческого билета без первой цифры
const int pages = 3 + 0 + 7 + 1 + 2;

/*
 * Функция инициализации буферной памяти через проецируемый файл
 * Параметры:
 *   buffSize - размер буфера в байтах
 *   isReader - признак процесса-читателя (true) или писателя (false)
 * Возвращает:
 *   Указатель на отображенную область памяти
 */
LPVOID initBuffer(int buffSize, bool isReader) {
    // Создаем или открываем файл для буфера
    HANDLE file = CreateFileA(
        "buffer.dat",                                     // Имя файла в текущей директории
        GENERIC_READ | GENERIC_WRITE,                     // Доступ на чтение и запись
        FILE_SHARE_READ | FILE_SHARE_WRITE,               // Разрешаем общий доступ
        NULL,                                             // Атрибуты безопасности по умолчанию
        isReader ? OPEN_EXISTING : CREATE_ALWAYS,         // Открыть или создать файл
        FILE_ATTRIBUTE_NORMAL,                            // Обычный файл
        NULL                                              // Без шаблона
    );

    if (file == INVALID_HANDLE_VALUE) {
        cout << "Ошибка создания/открытия файла. Код ошибки: " << GetLastError() << endl;
        exit(1);
    }

    // Пытаемся открыть существующий проецируемый файл
    HANDLE buffer = OpenFileMappingA(FILE_MAP_ALL_ACCESS, FALSE, "SharedBuffer");
    if (buffer == NULL) {
        buffer = CreateFileMappingA(
            file,                 // Файл для отображения
            NULL,                 // Атрибуты безопасности
            PAGE_READWRITE,       // Доступ на чтение и запись
            0,                    // Старшие 32 бита размера
            buffSize,            // Младшие 32 бита размера
            "SharedBuffer"       // Имя объекта в пространстве имен ядра
        );

        if (buffer == NULL) {
            cout << "Ошибка создания проецируемого файла. Код ошибки: " << GetLastError() << endl;
            CloseHandle(file);
            exit(1);
        }
    }

    // Отображаем файл в адресное пространство процесса
    LPVOID buffAddress = MapViewOfFile(
        buffer,                   // Объект проецируемого файла
        FILE_MAP_ALL_ACCESS,      // Полный доступ
        0, 0,                     // Смещение от начала файла
        buffSize                  // Размер отображения
    );

    if (buffAddress == NULL) {
        cout << "Ошибка отображения файла в память. Код ошибки: " << GetLastError() << endl;
        CloseHandle(buffer);
        CloseHandle(file);
        exit(1);
    }

    // Блокируем страницы буфера в оперативной памяти
    if (!VirtualLock(buffAddress, buffSize)) {
        cout << "Ошибка блокировки памяти. Код ошибки: " << GetLastError() << endl;
    }
    else {
        cout << "Страницы буфера заблокированы в ОЗУ" << endl;
    }

    // Закрываем дескриптор файла (отображение остается активным)
    CloseHandle(file);
    return buffAddress;
}

/*
 * Функция инициализации объектов синхронизации
 * Создает или открывает существующие мьютексы и семафоры
 */
void initSyncObjects() {
    // Мьютекс для защиты счетчика активных читателей
    mutex = OpenMutexA(MUTEX_ALL_ACCESS, FALSE, "ReaderCountMutex");
    if (mutex == NULL) {
        mutex = CreateMutexA(NULL, FALSE, "ReaderCountMutex");
    }

    // Семафор для писателей
    wrt = OpenSemaphoreA(SEMAPHORE_ALL_ACCESS, FALSE, "WriterSemaphore");
    if (wrt == NULL) {
        wrt = CreateSemaphoreA(NULL, 1, 1, "WriterSemaphore");
    }

    // Создаем массив мьютексов для каждой страницы буфера
    pageMutexes = new HANDLE[pages];
    for (int i = 0; i < pages; i++) {
        string name = "PageMutex_" + to_string(i);
        pageMutexes[i] = OpenMutexA(MUTEX_ALL_ACCESS, FALSE, name.c_str());
        if (pageMutexes[i] == NULL) {
            pageMutexes[i] = CreateMutexA(NULL, FALSE, name.c_str());
        }
    }
    cout << "Объекты синхронизации инициализированы" << endl;
}

/*
 * Функция записи состояния в журнальный файл
 */
void journalState(fstream& journal, const char* state, int page = -1) {
    journal << setw(10) << GetCurrentProcessId() << " | "
        << setw(10) << timeGetTime() << " | "
        << setw(15) << state << " | ";
    if (page >= 0) {
        journal << setw(10) << page;
    }
    journal << endl;
}

int main(int argc, char* argv[]) {
    // Настройка консоли для корректного отображения русского языка
    // Используем UTF-8 как в рабочем примере
    SetConsoleCP(65001);
    SetConsoleOutputCP(65001);
    setlocale(LC_ALL, ".UTF8");

    // Очистка экрана консоли
    system("cls");

    // Инициализация генератора случайных чисел
    srand((unsigned int)time(NULL));

    // Получаем системную информацию для определения размера страницы
    SYSTEM_INFO sysInfo;
    GetSystemInfo(&sysInfo);
    const int pageSize = sysInfo.dwPageSize;
    const int buffSize = pageSize * pages;

    // Определяем тип процесса по аргументу командной строки
    bool isReader = (argc > 1 && strcmp(argv[1], "reader") == 0);
    cout << (isReader ? "ПРОЦЕСС ЧИТАТЕЛЬ" : "ПРОЦЕСС ПИСАТЕЛЬ") << endl;
    cout << "Количество страниц: " << pages << endl;
    cout << "Размер страницы: " << pageSize << " байт" << endl;
    cout << "Общий размер буфера: " << buffSize << " байт" << endl;

    // Выделяем локальный буфер для операций чтения/записи
    char* localBuffer = new char[pageSize];
    if (!isReader) {
        // Писатель заполняет буфер случайным символом
        memset(localBuffer, 97 + rand() % 26, pageSize);
    }

    // Инициализация буферной памяти и объектов синхронизации
    LPVOID buffAddress = initBuffer(buffSize, isReader);
    initSyncObjects();

    // Открываем журнальный файл для записи состояний
    fstream journal;
    journal.open(isReader ? "ReaderJournal.txt" : "WriterJournal.txt",
        ios::app | ios::out);

    // Заголовок новой сессии в журнале
    journal << "\nНовая сессия начата в " << timeGetTime() << endl;
    journal << setw(10) << "ID ПРОЦЕССА" << " | "
        << setw(10) << "ВРЕМЯ" << " | "
        << setw(15) << "СОСТОЯНИЕ" << " | "
        << setw(10) << "СТРАНИЦА" << endl;

    cout << setw(25) << "АДРЕС" << " | "
        << setw(10) << "СТРАНИЦА" << endl;

    // Основной цикл работы процесса
    while (true) {
        if (isReader) {
            // Логика работы читателя

            // Записываем начало ожидания доступа
            journalState(journal, "Ожидание");

            // Выбираем случайную страницу для чтения
            int targetPage = rand() % pages;

            // Вход читателя: увеличиваем счетчик активных читателей
            WaitForSingleObject(mutex, INFINITE);
            readCount++;
            if (readCount == 1) {
                // Первый читатель блокирует писателей
                WaitForSingleObject(wrt, INFINITE);
            }
            ReleaseMutex(mutex);

            // Блокируем выбранную страницу для эксклюзивного доступа
            WaitForSingleObject(pageMutexes[targetPage], INFINITE);

            // Выполняем чтение данных со страницы
            journalState(journal, "Начало чтения", targetPage);

            // Вычисляем адрес страницы правильно для 64-битных систем
            char* pageAddress = (char*)buffAddress + (size_t)targetPage * pageSize;
            cout << setw(20) << (void*)pageAddress
                << " | " << setw(10) << targetPage << endl;

            // Копируем данные из разделяемой памяти в локальный буфер
            memcpy(localBuffer, pageAddress, pageSize);

            // Имитация длительности операции чтения: 500-1500 мс
            Sleep(500 + rand() % 1000);

            journalState(journal, "Конец чтения", targetPage);

            // Освобождаем страницу
            ReleaseMutex(pageMutexes[targetPage]);

            // Выход читателя: уменьшаем счетчик активных читателей
            WaitForSingleObject(mutex, INFINITE);
            readCount--;
            if (readCount == 0) {
                // Последний читатель освобождает писателей
                ReleaseSemaphore(wrt, 1, NULL);
            }
            ReleaseMutex(mutex);

            // Записываем состояние освобождения ресурсов
            journalState(journal, "Освобождение");

        }
        else {
            // Логика работы писателя

            // Записываем начало ожидания доступа
            journalState(journal, "Ожидание");

            // Выбираем случайную страницу для записи
            int targetPage = rand() % pages;

            // Ждем освобождения семафора писателей
            WaitForSingleObject(wrt, INFINITE);

            // Блокируем выбранную страницу
            WaitForSingleObject(pageMutexes[targetPage], INFINITE);

            // Выполняем запись данных на страницу
            journalState(journal, "Начало записи", targetPage);

            // Вычисляем адрес страницы правильно для 64-битных систем
            char* pageAddress = (char*)buffAddress + (size_t)targetPage * pageSize;
            cout << setw(20) << (void*)pageAddress
                << " | " << setw(10) << targetPage << endl;

            // Копируем данные из локального буфера в разделяемую память
            memcpy(pageAddress, localBuffer, pageSize);

            // Имитация длительности операции записи: 500-1500 мс
            Sleep(500 + rand() % 1000);

            journalState(journal, "Конец записи", targetPage);

            // Освобождаем страницу и семафор писателей
            ReleaseMutex(pageMutexes[targetPage]);
            ReleaseSemaphore(wrt, 1, NULL);

            // Записываем состояние освобождения ресурсов
            journalState(journal, "Освобождение");
        }
    }

    // Освобождение ресурсов (недостижимо в бесконечном цикле)
    delete[] localBuffer;
    journal.close();
    return 0;
}
