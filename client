// Подключаем заголовочные файлы (библиотеки)
#include <windows.h> // Главная библиотека Windows API (содержит все нужные функции для каналов, событий и т.д.)
#include <vector>    // Для хранения списка каналов
#include <iostream>  // Для ввода и вывода в консоль (cin, cout)
#include <fstream>   // Для работы с файлами (читаем файл со списком каналов)
#include <string>    // Для работы со строками
using namespace std; // Пространство имен std, чтобы не писать везде std::cout, std::string и т.д.

// Глобальные переменные для хранения важных объектов
HANDLE g_hPipe = INVALID_HANDLE_VALUE; // "Ручка" канала. Изначально недействительна.
HANDLE g_hEvent = NULL;                // "Ручка" события. Нужна для асинхронных операций.

// --- Функция для подключения к выбранному каналу ---
void ConnectToPipe() {
    char path[MAX_PATH]; // Буфер для хранения текущего пути (массив символов фиксированного размера)
    // Получаем полный путь к папке, где запущена наша программа
    GetCurrentDirectoryA(MAX_PATH, path);
    // Формируем путь к файлу PipeNames.txt. "\\..\\" означает "выйти из текущей папки в родительскую".
    // Сервер и клиент, видимо, запускаются из разных папок, а файл лежит в общей для них родительской папке.
    string filePath = string(path) + "\\..\\PipeNames.txt";

    // Открываем файл для чтения
    ifstream file(filePath);
    if (!file.is_open()) { // Проверяем, открылся ли файл
        cout << "Файл " << filePath << " не найден!" << endl;
        cout << "Сначала запустите сервер и создайте канал!" << endl;
        return; // Выходим из функции, подключиться не получится
    }

    vector<string> pipes; // Список для хранения имен каналов из файла
    string pipeName;      // Переменная для временного хранения прочитанного имени
    int i = 1;

    cout << "\nДоступные каналы:" << endl;
    // Читаем файл построчно, пока не кончится
    while (getline(file, pipeName)) {
        // Игнорируем пустые строки
        if (!pipeName.empty()) {
            cout << i++ << ". " << pipeName << endl; // Выводим номер и имя канала
            pipes.push_back(pipeName); // Добавляем имя в вектор
        }
    }
    file.close(); // Закрываем файл

    if (pipes.empty()) { // Если не прочитали ни одного имени канала
        cout << "Нет доступных каналов!" << endl;
        return;
    }

    // Спрашиваем пользователя, к какому каналу подключиться
    cout << "\nВыберите номер канала: ";
    int choice;
    cin >> choice;

    // Проверяем, правильный ли номер ввел пользователь
    if (choice < 1 || choice > pipes.size()) {
        cout << "Неверный номер!" << endl;
        return;
    }

    // Берем выбранное имя канала из вектора
    string selectedPipe = pipes[choice - 1]; // -1, потому что нумерация в векторе с 0

    // --- Создаем событие, если его еще нет ---
    // Событие нужно для асинхронного режима работы с каналом.
    if (g_hEvent == NULL) {
        // Параметры:
        // NULL - атрибуты безопасности по умолчанию
        // TRUE - событие с ручным сбросом
        // FALSE - начальное состояние: несигнальное (операция не завершена)
        // NULL - имя события не задаем
        g_hEvent = CreateEvent(NULL, TRUE, FALSE, NULL);
        if (g_hEvent == NULL) { // Если создать не удалось
            cout << "Ошибка создания события: " << GetLastError() << endl; // Выводим код ошибки
            return;
        }
    }

    // --- Подключаемся к именованному каналу ---
    g_hPipe = CreateFileA(
        selectedPipe.c_str(), // Имя канала в стиле C-строки
        GENERIC_READ,         // Мы будем только читать из канала
        0,                    // Нет разделения доступа
        NULL,                 // Атрибуты безопасности по умолчанию
        OPEN_EXISTING,        // Открываем только существующий канал
        FILE_FLAG_OVERLAPPED, // Открываем в режиме асинхронного (перекрывающегося) ввода/вывода
        NULL                  // Игнорируется для каналов
    );

    if (g_hPipe == INVALID_HANDLE_VALUE) { // Если подключиться не удалось
        cout << "Ошибка подключения: " << GetLastError() << endl;
        return;
    }

    cout << "Подключено к каналу: " << selectedPipe << endl;
}

// --- Функция для чтения данных из канала ---
void ReadData() {
    if (g_hPipe == INVALID_HANDLE_VALUE) { // Проверяем, подключены ли мы
        cout << "Сначала подключитесь к каналу!" << endl;
        return;
    }

    char buffer[1024] = { 0 }; // Буфер для приема данных (массив на 1024 символа, заполнен нулями)
    DWORD bytesRead = 0;       // Сюда запишется, сколько байт реально прочитано

    // Структура для асинхронной операции
    OVERLAPPED overlapped = { 0 }; // Обнуляем все поля структуры
    overlapped.hEvent = g_hEvent;   // Связываем структуру с нашим событием

    cout << "Ожидание данных..." << endl;

    // Начинаем асинхронное чтение
    BOOL result = ReadFile(
        g_hPipe,                // Из какого канала читаем
        buffer,                 // В какой буфер
        sizeof(buffer) - 1,    // Максимальный размер для чтения (минус 1 для '\0')
        NULL,                   // Количество прочитанных байт НЕ ЗАПОЛНЯЕМ (для асинхронного режима)
        &overlapped             // Указатель на структуру OVERLAPPED
    );

    if (!result) { // Если ReadFile вернул FALSE
        DWORD error = GetLastError(); // Смотрим, какая ошибка
        // ERROR_IO_PENDING — это не ошибка, а штатное поведение для асинхронного режима. Операция начата и ждёт.
        if (error == ERROR_IO_PENDING) {
            cout << "Асинхронное чтение запущено..." << endl;
            // Ждем завершения операции, но не более 60 секунд (60000 миллисекунд)
            DWORD waitResult = WaitForSingleObject(g_hEvent, 60000);

            if (waitResult == WAIT_OBJECT_0) { // Операция завершена успешно
                // Получаем результат операции. bytesRead здесь реально заполнится.
                if (GetOverlappedResult(g_hPipe, &overlapped, &bytesRead, FALSE)) {
                    buffer[bytesRead] = '\0'; // Добавляем завершающий ноль, чтобы вывести как строку
                    cout << "Получено " << bytesRead << " байт: " << buffer << endl;
                }
            }
            else if (waitResult == WAIT_TIMEOUT) { // Время вышло
                cout << "Таймаут ожидания!" << endl;
                CancelIo(g_hPipe); // Отменяем операцию ввода/вывода для этого канала
            }
        }
        else { // Действительно ошибка
            cout << "Ошибка чтения: " << error << endl;
        }
    }
    else { // Если ReadFile вернул TRUE, операция мгновенно завершилась (данные уже были в буфере канала)
        // Все равно нужно получить результат, чтобы узнать bytesRead
        if (GetOverlappedResult(g_hPipe, &overlapped, &bytesRead, FALSE)) {
            buffer[bytesRead] = '\0';
            cout << "Получено " << bytesRead << " байт: " << buffer << endl;
        }
    }
}

// --- Функция для отключения от канала ---
void DisconnectFromPipe() {
    if (g_hPipe != INVALID_HANDLE_VALUE) { // Если мы подключены
        CloseHandle(g_hPipe);              // Закрываем "ручку" канала
        g_hPipe = INVALID_HANDLE_VALUE;    // Сбрасываем значение в "недействительно"
        cout << "Отключено от канала!" << endl;
    }
    else {
        cout << "Нет активного подключения!" << endl;
    }
}

// --- Главная функция клиента ---
int main() {
    // Настройка консоли для корректного отображения кириллицы
    SetConsoleCP(65001);       // Устанавливаем кодировку ввода как UTF-8
    SetConsoleOutputCP(65001); // Устанавливаем кодировку вывода как UTF-8
    setlocale(LC_ALL, "ru_RU.UTF-8");

    cout << "Клиент именованного канала" << endl;

    int ans; // Переменная для выбора пункта меню
    while (true) { // Бесконечный цикл, пока пользователь не выберет "0"
        // Выводим меню
        cout << "\nМЕНЮ:" << endl;
        cout << "1. Подключиться к каналу" << endl;
        cout << "2. Прочитать данные" << endl;
        cout << "3. Отключиться от канала" << endl;
        cout << "0. Выход" << endl;
        cout << "Выбор: ";
        cin >> ans;

        // Обрабатываем выбор
        switch (ans) {
        case 1: ConnectToPipe(); break;   // Вызов функции подключения
        case 2: ReadData(); break;        // Вызов функции чтения
        case 3: DisconnectFromPipe(); break; // Вызов функции отключения
        case 0:
            // Перед выходом корректно освобождаем ресурсы
            if (g_hPipe != INVALID_HANDLE_VALUE) CloseHandle(g_hPipe); // Закрываем канал, если открыт
            if (g_hEvent != NULL) CloseHandle(g_hEvent);              // Закрываем событие, если создано
            return 0; // Завершаем программу
        default:
            cout << "Неверный выбор!" << endl; // Если ввели не 0-3
        }
    }
}
