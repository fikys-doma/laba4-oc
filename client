#include <windows.h>
#include <vector>
#include <iostream>
#include <fstream>
#include <string>
using namespace std;

// Глобальные переменные
HANDLE g_hPipe = INVALID_HANDLE_VALUE; //хранение дескриптор открытого именованного канала
HANDLE g_hEvent = NULL;

BOOL g_bReadCompleted = FALSE;
DWORD g_dwBytesRead = 0;         // Сколько байт реально прочитано
char g_buffer[1024] = { 0 };     // Глобальный буфер для чтения

VOID CALLBACK ReadCompletionRoutine(
    DWORD dwErrorCode,
    DWORD dwNumberOfBytesTransfered,
    LPOVERLAPPED lpOverlapped
)
{
    g_dwBytesRead = dwNumberOfBytesTransfered; // Сохраняем количество прочитанных байт
    g_bReadCompleted = TRUE;                   // Поднимаем флаг — готово

    // Устанавливаем событие, чтобы разбудить основной поток,
    // если он ждёт на WaitForSingleObjectEx
    if (g_hEvent != NULL) {
        SetEvent(g_hEvent);
    }
}

// --- Функция для подключения к выбранному каналу ---
void ConnectToPipe() {
    char path[MAX_PATH];
    GetCurrentDirectoryA(MAX_PATH, path);
    string filePath = string(path) + "\\..\\PipeNames.txt";

    ifstream file(filePath);
    if (!file.is_open()) {
        cout << "Файл " << filePath << " не найден!" << endl;
        cout << "Сначала запустите сервер и создайте канал!" << endl;
        return;
    }

    vector<string> pipes;
    string pipeName;
    int i = 1;

    cout << "\nДоступные каналы:" << endl;
    while (getline(file, pipeName)) {
        if (!pipeName.empty()) {
            cout << i++ << ". " << pipeName << endl;
            pipes.push_back(pipeName);
        }
    }
    file.close();

    if (pipes.empty()) {
        cout << "Нет доступных каналов!" << endl;
        return;
    }

    cout << "\nВыберите номер канала: ";
    int choice;
    cin >> choice;

    if (choice < 1 || choice > pipes.size()) {
        cout << "Неверный номер!" << endl;
        return;
    }

    string selectedPipe = pipes[choice - 1];

    // Создаем событие (нужно для пробуждения потока из callback)
    if (g_hEvent == NULL) {
        g_hEvent = CreateEvent(NULL, TRUE, FALSE, NULL);
        if (g_hEvent == NULL) {
            cout << "Ошибка создания события: " << GetLastError() << endl;
            return;
        }
    }

    // Подключаемся к каналу
    g_hPipe = CreateFileA(
        selectedPipe.c_str(),
        GENERIC_READ,
        0,
        NULL,
        OPEN_EXISTING,
        FILE_FLAG_OVERLAPPED,   // Асинхронный режим обязателен для ReadFileEx
        NULL
    );

    if (g_hPipe == INVALID_HANDLE_VALUE) {
        cout << "Ошибка подключения: " << GetLastError() << endl;
        return;
    }

    cout << "Подключено к каналу: " << selectedPipe << endl;
}

// --- Функция для чтения данных из канала (ReadFileEx + callback) ---
void ReadData() {
    if (g_hPipe == INVALID_HANDLE_VALUE) {
        cout << "Сначала подключитесь к каналу!" << endl;
        return;
    }

    // Сбрасываем флаг и счётчик перед новой операцией
    g_bReadCompleted = FALSE;
    g_dwBytesRead = 0;
    memset(g_buffer, 0, sizeof(g_buffer));

    // Структура OVERLAPPED. Для ReadFileEx поле hEvent НЕ ИСПОЛЬЗУЕТСЯ.
    OVERLAPPED overlapped = { 0 };

    cout << "Ожидание данных..." << endl;

    // Запускаем асинхронное чтение с callback-функцией
    BOOL result = ReadFileEx(
        g_hPipe,                    // Дескриптор канала
        g_buffer,
        sizeof(g_buffer) - 1,
        &overlapped,
        ReadCompletionRoutine
    );

    if (!result) {
        DWORD error = GetLastError();
        cout << "Ошибка запуска чтения: " << error << endl;
        return;
    }

    DWORD waitResult = WaitForSingleObjectEx(g_hEvent, 60000, TRUE);

    if (waitResult == WAIT_OBJECT_0) {
        if (g_bReadCompleted) {
            g_buffer[g_dwBytesRead] = '\0';
            cout << "Получено " << g_dwBytesRead << " байт: " << g_buffer << endl;
        }
    }
    else if (waitResult == WAIT_IO_COMPLETION) {
        if (g_bReadCompleted) {
            g_buffer[g_dwBytesRead] = '\0';
            cout << "Получено " << g_dwBytesRead << " байт: " << g_buffer << endl;
        }
    }
    else if (waitResult == WAIT_TIMEOUT) {
        cout << "Таймаут ожидания!" << endl;
        CancelIo(g_hPipe);
        g_bReadCompleted = FALSE;
    }
    else {
        cout << "Ошибка ожидания: " << GetLastError() << endl;
    }

    ResetEvent(g_hEvent);
}

void DisconnectFromPipe() {
    if (g_hPipe != INVALID_HANDLE_VALUE) {
        CloseHandle(g_hPipe);
        g_hPipe = INVALID_HANDLE_VALUE;
        cout << "Отключено от канала!" << endl;
    }
    else {
        cout << "Нет активного подключения!" << endl;
    }
}

int main() {
    SetConsoleCP(65001);
    SetConsoleOutputCP(65001);
    setlocale(LC_ALL, "ru_RU.UTF-8");

    cout << "Клиент именованного канала (ReadFileEx + callback)" << endl;

    int ans;
    while (true) {
        cout << "\nМЕНЮ:" << endl;
        cout << "1. Подключиться к каналу" << endl;
        cout << "2. Прочитать данные" << endl;
        cout << "3. Отключиться от канала" << endl;
        cout << "0. Выход" << endl;
        cout << "Выбор: ";
        cin >> ans;

        switch (ans) {
        case 1: ConnectToPipe(); break;
        case 2: ReadData(); break;
        case 3: DisconnectFromPipe(); break;
        case 0:
            if (g_hPipe != INVALID_HANDLE_VALUE) CloseHandle(g_hPipe);
            if (g_hEvent != NULL) CloseHandle(g_hEvent);
            return 0;
        default:
            cout << "Неверный выбор!" << endl;
        }
    }
}
